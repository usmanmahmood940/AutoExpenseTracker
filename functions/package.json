{
  "name": "auto-expense-tracker-functions",
  "description": "Cloud Functions for Auto Expense Tracker webhook ingestion",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions,firestore",
    "shell": "npm run build && firebase functions:shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "test": "npm run build && node --test lib",
    "test:ingest": "node scripts/test-ingest.mjs",
    "seed:categories": "npm run build && node scripts/seed-categories.mjs",
    "backfill:merchant-normalized": "npm run build && node scripts/backfill-merchant-normalized.mjs"
  },
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "firebase-admin": "^13.4.0",
    "firebase-functions": "^6.3.2"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  },
  "private": true
}
