rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Legacy (single-user webhook):
    //   transactions/{transactionId}
    //   raw_ingestions/{ingestionId}
    // Multi-user:
    //   users/{userId}
    //   users/{userId}/transactions/{transactionId}
    //   users/{userId}/raw_ingestions/{ingestionId}
    //   users/{userId}/categories/{categoryId}  (user-created)
    // Global defaults (webhook categorization source):
    //   categories/{categoryId}
    //
    // All writes go through Cloud Functions (Admin SDK).
    // Client apps will get read access in Phase 5 with Firebase Auth.
    // ===============================================================

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
